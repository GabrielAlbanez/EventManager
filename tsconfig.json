{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["react", "react-native", "react-native-vector-icons"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    }
  }
}
